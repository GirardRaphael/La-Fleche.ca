# ─── Required ────────────────────────────────────────────────────
# Resend API key — create one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional ────────────────────────────────────────────────────
# Sender address (must be a verified Resend domain). Defaults to onboarding@resend.dev
RESEND_FROM_EMAIL=La Fleche AI <no-reply@la-fleche.ca>

# Email that receives form submissions. Defaults to xxraphaelgirardxx@gmail.com
CONTACT_RECIPIENT_EMAIL=xxraphaelgirardxx@gmail.com

# Upstash Redis for distributed rate limiting across serverless instances.
# Without these, fallback in-memory rate limiter is used (resets on cold start).
# Create a free database at https://upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Allowed CORS origin for the contact API. Defaults to https://la-fleche.ca
ALLOWED_ORIGIN=https://la-fleche.ca
